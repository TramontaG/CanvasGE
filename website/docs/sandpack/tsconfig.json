{
  "compilerOptions": {
    "target": "ESNext",
    "module": "Preserve",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "resolveJsonModule": true,
    "experimentalDecorators": true,
    "strict": false,
    "noEmit": true,
    "skipLibCheck": true,
    "baseUrl": "../../../",
    "paths": {
      "sliver-engine": ["src/index.ts"]
    }
  },
  "include": ["./**/*.ts"]
}
